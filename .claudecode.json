{
  "ignore": [
    "venv/**",
    "**/__pycache__/**",
    "**/*.pyc",
    "**/*.pyo",
    "node_modules/**",
    "frontend/node_modules/**",
    "**/*.tmp",
    "**/*.json.tmp",
    ".next/**",
    "dist/**",
    "build/**",
    "*.egg-info/**",
    ".pytest_cache/**",
    "htmlcov/**",
    ".coverage",
    "cometa_key.json",
    ".env",
    "*.env.*"
  ],
  "permissions": {
    "edit": [
      "src/**",
      "frontend/src/**",
      "CLAUDE.md",
      "requirements.txt",
      "frontend/package.json"
    ],
    "read": [
      "**"
    ]
  }
}
